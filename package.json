{
  "name": "chameleon",
  "version": "0.1.0",
  "description": "A Schema-driven API protocol conversion gateway that seamlessly transforms APIs between REST, GraphQL, and gRPC",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "bin": {
    "chameleon": "./dist/src/server/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucientong/chameleon.git"
  },
  "bugs": {
    "url": "https://github.com/lucientong/chameleon/issues"
  },
  "homepage": "https://github.com/lucientong/chameleon#readme",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "gateway",
    "rest",
    "graphql",
    "grpc",
    "openapi",
    "protobuf",
    "protocol",
    "converter",
    "schema"
  ],
  "author": "lucientong",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@fastify/cors": "^8.5.0",
    "fastify-plugin": "^4.5.1",
    "@graphql-tools/schema": "^10.0.0",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "dataloader": "^2.2.2",
    "fastify": "^4.24.0",
    "graphql": "^16.8.0",
    "graphql-yoga": "^5.19.0",
    "protobufjs": "^7.2.0",
    "ws": "^8.14.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "openapi-types": "^12.1.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
